[Unit]
Description=Nomad Eye Backend
After=network.target

[Service]
User=arduino
WorkingDirectory=/opt/nomad-eye/backend
Environment="PATH=/opt/nomad-eye/backend/venv/bin"
ExecStart=/opt/nomad-eye/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
