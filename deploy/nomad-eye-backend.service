[Unit]
Description=Nomad Eye Backend
After=network.target

[Service]
User=arduino
WorkingDirectory=/opt/nomad-eye/backend
Environment=PATH=/opt/nomad-eye/backend/venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/opt/nomad-eye/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 80
Restart=always
RestartSec=5
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
