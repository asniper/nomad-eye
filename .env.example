# Nomad Eye — Environment Configuration
# Copy this file to .env and edit the values before starting the service.
# Place .env in the project root: /opt/nomad-eye/.env

# ── Authentication ────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Secret key used for session signing. Use a long random string in production.
SECRET_KEY=change-me-in-production

# ── Data Paths ────────────────────────────────────────────────────────────────
# Defaults point to /opt/nomad-eye/data/ — only change if using custom paths.
# DB_PATH=/opt/nomad-eye/data/db/nomadeye.db
# IMAGES_DIR=/opt/nomad-eye/data/images
# CLIPS_DIR=/opt/nomad-eye/data/clips

# ── Detection ─────────────────────────────────────────────────────────────────
# Default confidence threshold (0.0–1.0). Per-category thresholds are set in the UI.
# DETECTION_CONFIDENCE=0.5

# Motion pixel threshold before AI runs. Higher = less sensitive.
# MOTION_THRESHOLD=100

# Seconds of video to save before and after each detection event.
# CLIP_SECONDS_BEFORE=5
# CLIP_SECONDS_AFTER=5

# ── Hotspot (AP Mode) ─────────────────────────────────────────────────────────
# SSID and password for the built-in setup hotspot.
# AP_SSID=NomadEye-Setup
# AP_PASSWORD=nomadeye123
